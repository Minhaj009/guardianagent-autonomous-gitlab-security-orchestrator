<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>GuardianAgent - Portal Login</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Courier+Prime&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary": "#375561",
                        "primary-container": "#4f6d7a",
                        "background": "#f2fbff",
                        "surface": "#ffffff",
                        "surface-dim": "#c8dee7",
                        "surface-bright": "#f2fbff",
                        "on-surface": "#091e25",
                        "on-surface-variant": "#42484b",
                        "outline": "#72787b",
                        "outline-variant": "#c2c7cb",
                        "secondary": "#a04118",
                        "secondary-container": "#fe8859",
                        "tertiary": "#685e3e",
                        "tertiary-container": "#b7ab86"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1.5rem"
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-background text-on-surface antialiased min-h-screen flex items-center justify-center px-4 font-sans">
    <div class="w-full max-w-md my-12">
        <!-- Logo and header -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center p-4 bg-white border border-outline-variant rounded-xl shadow-sm mb-4">
                <span class="material-symbols-outlined text-primary text-4xl" style="font-variation-settings: 'FILL' 1;">shield</span>
            </div>
            <h1 class="text-2xl font-bold tracking-tight text-primary uppercase">GuardianAgent</h1>
            <p class="text-[10px] uppercase tracking-widest text-on-surface-variant mt-1.5 font-bold">Autonomous Security Orchestrator</p>
        </div>

        <!-- Custom Card -->
        <div class="bg-surface rounded-2xl border border-outline-variant p-10 shadow-sm">
            <!-- Auth switch tabs -->
            <div class="flex border border-outline-variant rounded-lg bg-background p-1 mb-8">
                <button id="loginTab" onclick="switchTab('login')" class="flex-1 py-2 rounded text-xs font-bold uppercase tracking-wider transition-all duration-200 bg-primary text-white cursor-pointer">
                    Sign In
                </button>
                <button id="signupTab" onclick="switchTab('signup')" class="flex-1 py-2 rounded text-xs font-bold uppercase tracking-wider transition-all duration-200 text-on-surface-variant hover:text-primary cursor-pointer">
                    Register
                </button>
            </div>

            <!-- Error and Success Alerts -->
            <% if (error) { %>
                <div class="mb-6 p-4 rounded-lg border border-red-200 text-red-700 bg-red-50 text-xs flex items-center gap-3">
                    <span class="material-symbols-outlined text-sm flex-shrink-0" style="font-variation-settings: 'FILL' 1;">error</span>
                    <span class="font-semibold"><%= error %></span>
                </div>
            <% } %>
            <% if (success) { %>
                <div class="mb-6 p-4 rounded-lg border border-emerald-200 text-emerald-700 bg-emerald-50 text-xs flex items-center gap-3">
                    <span class="material-symbols-outlined text-sm flex-shrink-0" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                    <span class="font-semibold"><%= success %></span>
                </div>
            <% } %>

            <!-- Form -->
            <form id="authForm" action="/login" method="POST" class="space-y-6">
                <div>
                    <label for="email" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">Email Address</label>
                    <input type="email" name="email" id="email" required placeholder="developer@example.com" 
                           class="w-full bg-background border border-outline-variant rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all duration-200 text-on-surface">
                </div>

                <div>
                    <label for="password" class="block text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">Password</label>
                    <input type="password" name="password" id="password" required placeholder="••••••••••••" 
                           class="w-full bg-background border border-outline-variant rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all duration-200 text-on-surface">
                </div>

                <button type="submit" id="submitBtn" 
                        class="w-full py-3.5 bg-secondary hover:opacity-90 text-white font-bold uppercase tracking-wider text-xs rounded-lg transition-all duration-200 cursor-pointer shadow-sm">
                    Sign In to Console
                </button>
            </form>
        </div>
    </div>

    <script>
        function switchTab(mode) {
            const form = document.getElementById('authForm');
            const submitBtn = document.getElementById('submitBtn');
            const loginTab = document.getElementById('loginTab');
            const signupTab = document.getElementById('signupTab');

            if (mode === 'signup') {
                form.action = '/signup';
                submitBtn.innerText = 'Create Account';
                
                signupTab.className = 'flex-1 py-2 rounded text-xs font-bold uppercase tracking-wider transition-all duration-200 bg-primary text-white cursor-pointer';
                loginTab.className = 'flex-1 py-2 rounded text-xs font-bold uppercase tracking-wider transition-all duration-200 text-on-surface-variant hover:text-primary cursor-pointer';
            } else {
                form.action = '/login';
                submitBtn.innerText = 'Sign In to Console';
                
                loginTab.className = 'flex-1 py-2 rounded text-xs font-bold uppercase tracking-wider transition-all duration-200 bg-primary text-white cursor-pointer';
                signupTab.className = 'flex-1 py-2 rounded text-xs font-bold uppercase tracking-wider transition-all duration-200 text-on-surface-variant hover:text-primary cursor-pointer';
            }
        }
    </script>
</body>
</html>
