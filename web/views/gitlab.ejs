<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>GuardianAgent - GitLab Repository Connections</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Courier+Prime:wght@400;700&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary": "#375561",
                        "primary-container": "#4f6d7a",
                        "background": "#f2fbff",
                        "surface": "#ffffff",
                        "surface-dim": "#c8dee7",
                        "surface-bright": "#f2fbff",
                        "on-surface": "#091e25",
                        "on-surface-variant": "#42484b",
                        "outline": "#72787b",
                        "outline-variant": "#c2c7cb",
                        "secondary": "#a04118",
                        "secondary-container": "#fe8859",
                        "tertiary": "#685e3e",
                        "tertiary-container": "#b7ab86"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1.5rem"
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body-md min-h-screen flex flex-col antialiased">

    <!-- Sticky Top Navigation -->
    <header class="bg-surface sticky top-0 w-full z-50 border-b border-outline-variant">
        <div class="flex justify-between items-center w-full px-6 h-16 max-w-7xl mx-auto">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">shield</span>
                    <span class="font-bold text-lg text-primary tracking-tight">GuardianAgent</span>
                    <span class="text-[10px] border border-outline text-primary px-1.5 py-0.5 ml-2 font-mono uppercase font-bold rounded">v1.0.0</span>
                </div>
                <nav class="hidden md:flex items-center gap-6 ml-4">
                    <a href="/dashboard" class="text-xs font-bold uppercase tracking-wider transition-all duration-200 py-1.5 px-3 border border-outline-variant/30 text-on-surface-variant hover:text-primary rounded-lg cursor-pointer">
                        Review Dashboard
                    </a>
                    <a href="/setup/gitlab" class="text-xs font-bold uppercase tracking-wider transition-all duration-200 py-1.5 px-3 border border-outline-variant/30 bg-surface-dim text-primary rounded-lg cursor-pointer">
                        GitLab Setup
                    </a>
                </nav>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="text-right hidden sm:block">
                    <p class="text-[10px] text-on-surface-variant uppercase tracking-widest font-semibold">User</p>
                    <p class="text-xs font-bold text-primary"><%= userEmail %></p>
                </div>
                <a href="/logout" class="py-2 px-3 border border-outline text-xs font-bold uppercase tracking-wider text-primary hover:bg-surface-dim transition-all duration-200 cursor-pointer rounded-lg" title="Logout">
                    Logout
                </a>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 max-w-4xl mx-auto w-full px-6 py-10 space-y-10">
        <header class="mb-4">
            <h1 class="text-3xl font-bold text-primary mb-2">GitLab Account Integration</h1>
            <p class="text-on-surface-variant text-sm leading-relaxed">
                Securely connect your GitLab account, list repositories, and enable Guardian agent scan orchestrations with a single click.
            </p>
        </header>

        <% if (!hasGitlabToken) { %>
            <!-- Connect Token Form -->
            <section class="bg-surface rounded-2xl border border-outline-variant p-8 shadow-sm space-y-6">
                <div>
                    <h2 class="text-lg font-bold text-primary uppercase tracking-wider">Connect GitLab Account</h2>
                    <p class="text-on-surface-variant text-xs mt-1">Provide a GitLab Personal Access Token to link your project repositories.</p>
                </div>

                <form action="/settings/update-gitlab" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-[10px] font-bold uppercase tracking-wider text-on-surface-variant mb-2">Personal Access Token (PAT)</label>
                        <input type="password" name="gitlab_token" required placeholder="glpat-xxxxxxxxxxxxxxxxxxxx"
                               class="w-full bg-background border border-outline-variant rounded-lg text-on-surface text-xs px-4 py-3 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-mono">
                    </div>
                    <div class="text-[11px] text-on-surface-variant leading-relaxed">
                        💡 To create a token, visit your <a href="https://gitlab.com/-/profile/personal_access_tokens" target="_blank" class="text-secondary hover:underline font-semibold">GitLab PAT Settings</a> and create a token with scopes: <code class="bg-background px-1 rounded font-mono">api</code>, <code class="bg-background px-1 rounded font-mono">read_repository</code>, and <code class="bg-background px-1 rounded font-mono">write_repository</code>.
                    </div>
                    <div class="flex justify-end pt-2">
                        <button type="submit" class="px-6 py-2.5 bg-secondary hover:opacity-90 text-white text-xs font-bold uppercase tracking-wider rounded-lg cursor-pointer transition-all shadow-sm flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-sm">link</span>
                            Link GitLab Account
                        </button>
                    </div>
                </form>
            </section>
        <% } else { %>
            <!-- Connected View & Repository Selector -->
            <section class="bg-surface rounded-2xl border border-outline-variant p-8 shadow-sm space-y-6">
                <div class="flex items-center justify-between border-b border-outline-variant/30 pb-4">
                    <div class="flex items-center gap-3">
                        <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-emerald-50 border border-emerald-300 text-emerald-700 text-[10px] font-bold uppercase tracking-wider rounded-full">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-600"></span>
                            <span>Connected</span>
                        </div>
                        <h2 class="text-lg font-bold text-primary uppercase tracking-wider">Your GitLab Repositories</h2>
                    </div>
                    <form action="/settings/update-gitlab" method="POST" onsubmit="return confirm('Disconnecting will prevent scans from authenticating. Continue?')">
                        <input type="hidden" name="gitlab_token" value="disconnect">
                        <button type="submit" class="text-[10px] text-secondary hover:underline uppercase font-bold flex items-center gap-1">
                            <span class="material-symbols-outlined text-xs">link_off</span> Disconnect Account
                        </button>
                    </form>
                </div>

                <!-- Repo search & dynamic list -->
                <div class="space-y-4">
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3.5 top-2.5 text-outline text-sm">search</span>
                        <input type="text" id="repoSearch" oninput="filterRepos()" placeholder="Search repositories..."
                               class="w-full pl-10 bg-background border border-outline-variant rounded-lg text-on-surface text-xs py-2.5 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-semibold">
                    </div>

                    <!-- Loader -->
                    <div id="repoLoader" class="flex justify-center items-center py-12">
                        <span class="material-symbols-outlined animate-spin text-primary text-3xl">sync</span>
                    </div>

                    <!-- List Container -->
                    <div id="repoListContainer" class="hidden border border-outline-variant rounded-xl overflow-hidden divide-y divide-outline-variant bg-surface">
                        <!-- Dynamically populated -->
                    </div>
                </div>
            </section>
        <% } %>
    </main>

    <!-- Footer -->
    <footer class="bg-surface w-full py-4 mt-auto border-t border-outline-variant">
        <div class="max-w-7xl mx-auto px-6 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-2">
                <span class="font-bold text-primary text-sm">GuardianAgent</span>
                <span class="text-on-surface-variant text-[10px]">© 2026 GuardianAgent. All rights reserved.</span>
            </div>
        </div>
    </footer>

    <script>
        let allProjects = [];

        async function loadRepositories() {
            const loader = document.getElementById('repoLoader');
            const container = document.getElementById('repoListContainer');
            if (!container) return; // not connected state

            try {
                const response = await fetch('/api/gitlab/projects');
                const data = await response.json();
                
                loader.classList.add('hidden');
                container.classList.remove('hidden');

                if (response.ok && data.success) {
                    allProjects = data.projects;
                    renderProjects(allProjects);
                } else {
                    container.innerHTML = `
                        <div class="p-6 text-center text-xs font-semibold text-secondary uppercase">
                            ❌ ${data.error || 'Failed to retrieve projects.'}
                        </div>
                    `;
                }
            } catch (ex) {
                console.error('Error fetching repos:', ex);
                loader.classList.add('hidden');
                container.innerHTML = `
                    <div class="p-6 text-center text-xs font-semibold text-secondary uppercase">
                        ❌ Connection failure fetching projects.
                    </div>
                `;
            }
        }

        function renderProjects(projects) {
            const container = document.getElementById('repoListContainer');
            if (projects.length === 0) {
                container.innerHTML = `
                    <div class="p-8 text-center text-xs text-on-surface-variant font-medium">
                        No repositories found in your account.
                    </div>
                `;
                return;
            }

            container.innerHTML = projects.map(p => `
                <div class="flex justify-between items-center p-4 hover:bg-background/20 transition-colors" data-name="${p.path_with_namespace.toLowerCase()}">
                    <div class="space-y-0.5">
                        <a href="${p.web_url}" target="_blank" class="font-bold text-primary text-xs hover:underline flex items-center gap-1.5">
                            ${p.path_with_namespace}
                            <span class="material-symbols-outlined text-[10px]">open_in_new</span>
                        </a>
                        <p class="text-[10px] text-on-surface-variant font-medium font-mono">ID: ${p.id}</p>
                    </div>

                    <div class="flex items-center gap-4">
                        <label class="relative inline-flex items-center cursor-pointer select-none">
                            <input type="checkbox" onchange="toggleProject('${p.path_with_namespace}', ${p.id}, this)" ${p.is_active ? 'checked' : ''} class="sr-only peer">
                            <div class="w-9 h-5 bg-outline-variant rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-outline-variant after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary-container"></div>
                            <span class="ml-2.5 text-[10px] font-bold uppercase tracking-wider text-on-surface-variant peer-checked:text-primary">
                                ${p.is_active ? 'Active' : 'Inactive'}
                            </span>
                        </label>
                    </div>
                </div>
            `).join('');
        }

        function filterRepos() {
            const query = document.getElementById('repoSearch').value.toLowerCase().trim();
            const items = document.querySelectorAll('#repoListContainer > div');
            items.forEach(item => {
                const name = item.getAttribute('data-name');
                if (name && name.includes(query)) {
                    item.classList.remove('hidden');
                } else {
                    item.classList.add('hidden');
                }
            });
        }

        async function toggleProject(repoName, repoId, checkbox) {
            const labelSpan = checkbox.nextElementSibling.nextElementSibling;
            checkbox.disabled = true;

            try {
                const response = await fetch('/api/gitlab/toggle-repo', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        repo_name: repoName,
                        repo_id: repoId,
                        is_active: checkbox.checked
                    })
                });
                const data = await response.json();
                checkbox.disabled = false;

                if (response.ok && data.success) {
                    checkbox.checked = data.is_active;
                    if (labelSpan) {
                        labelSpan.textContent = data.is_active ? 'Active' : 'Inactive';
                    }
                } else {
                    checkbox.checked = !checkbox.checked;
                    alert('Failed to update repository status.');
                }
            } catch (ex) {
                console.error(ex);
                checkbox.disabled = false;
                checkbox.checked = !checkbox.checked;
                alert('Connection failure updating repository status.');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadRepositories();
        });
    </script>
</body>
</html>
