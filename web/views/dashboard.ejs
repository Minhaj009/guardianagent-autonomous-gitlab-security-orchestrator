<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GuardianAgent - Developer Console</title>
    <!-- Tailwind CSS v4 via CDN -->
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #EAEAEA;
        }
    </style>
</head>
<body class="bg-[#EAEAEA] text-[#4F6D7A] min-h-screen pb-12">

    <!-- Sticky Top Navigation -->
    <nav class="sticky top-0 z-50 bg-[#EAEAEA] border-b border-[#4F6D7A] px-6 py-4 flex items-center justify-between pointer-events-auto" style="pointer-events: auto;">
        <div class="flex items-center gap-3">
            <div class="p-2 bg-white border border-[#4F6D7A]">
                <svg class="w-6 h-6 text-[#4F6D7A]" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                </svg>
            </div>
            <div>
                <span class="font-bold text-lg text-[#4F6D7A] tracking-tight">GuardianAgent</span>
                <span class="text-[10px] border border-[#4F6D7A] text-[#4F6D7A] px-1.5 py-0.5 ml-2 font-mono uppercase font-bold">v1.0.0</span>
            </div>
        </div>

        <!-- Center links -->
        <div class="hidden md:flex items-center gap-4">
            <a href="/dashboard" class="text-xs font-bold uppercase tracking-wider transition-all duration-200 py-1.5 px-3 border border-[#4F6D7A]/30 <%= currentPath === '/dashboard' ? 'bg-[#E8DAB2] text-[#4F6D7A]' : 'text-[#4F6D7A]/60 hover:text-[#4F6D7A] hover:bg-[#C0D6DF]/20' %> cursor-pointer">
                Review Dashboard
            </a>
            <a href="/setup/github" class="text-xs font-bold uppercase tracking-wider transition-all duration-200 py-1.5 px-3 border border-[#4F6D7A]/30 <%= currentPath === '/setup/github' ? 'bg-[#E8DAB2] text-[#4F6D7A]' : 'border-transparent text-[#4F6D7A]/60 hover:text-[#4F6D7A] hover:bg-[#C0D6DF]/20' %> cursor-pointer">
                GitHub Setup
            </a>
            <a href="/setup/gitlab" class="text-xs font-bold uppercase tracking-wider transition-all duration-200 py-1.5 px-3 border border-[#4F6D7A]/30 <%= currentPath === '/setup/gitlab' ? 'bg-[#E8DAB2] text-[#4F6D7A]' : 'border-transparent text-[#4F6D7A]/60 hover:text-[#4F6D7A] hover:bg-[#C0D6DF]/20' %> cursor-pointer">
                GitLab Setup
            </a>
        </div>

        <div class="flex items-center gap-4">
            <div class="text-right hidden sm:block">
                <p class="text-[10px] text-[#4F6D7A]/60 uppercase tracking-widest font-semibold">User</p>
                <p class="text-xs font-bold text-[#4F6D7A]"><%= userEmail %></p>
            </div>
            <a href="/logout" class="py-2 px-3 border border-[#4F6D7A] text-xs font-bold uppercase tracking-wider text-[#4F6D7A] hover:bg-[#C0D6DF]/30 transition-all duration-200 cursor-pointer" title="Logout">
                Logout
            </a>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-10 space-y-10">
        <!-- Dashboard Header -->
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold uppercase tracking-tight text-[#4F6D7A]">Security Review Console</h1>
                <p class="text-[#4F6D7A]/80 text-xs mt-1.5 font-medium">Verify consensus reviews and patches generated by autonomous agent ensembles.</p>
            </div>
            <% if (isDemoMode) { %>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#E8DAB2]/20 border border-[#4F6D7A] text-[#4F6D7A] text-[10px] font-bold uppercase tracking-wider">
                    <span>Demo Sandbox Active</span>
                </div>
            <% } else { %>
                <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#C0D6DF]/20 border border-[#4F6D7A] text-[#4F6D7A] text-[10px] font-bold uppercase tracking-wider">
                    <span>Live Audit Mode Connected</span>
                </div>
            <% } %>
        </div>

        <!-- Metric Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Metric Card 1 -->
            <div class="bg-[#C0D6DF]/20 border border-[#4F6D7A] p-8 relative transition-all duration-200 hover:bg-[#C0D6DF]/30">
                <p class="text-[10px] font-bold text-[#4F6D7A]/70 uppercase tracking-wider">Active LLM Ensemble</p>
                <h3 class="text-3xl font-bold text-[#4F6D7A] mt-2">15</h3>
                <p class="text-[10px] text-[#4F6D7A]/80 mt-1 font-semibold">Consensus models loaded</p>
            </div>

            <!-- Metric Card 2 -->
            <div class="bg-[#C0D6DF]/20 border border-[#4F6D7A] p-8 relative transition-all duration-200 hover:bg-[#C0D6DF]/30">
                <p class="text-[10px] font-bold text-[#4F6D7A]/70 uppercase tracking-wider">Vulnerabilities Found</p>
                <h3 id="metricVulns" class="text-3xl font-bold text-[#4F6D7A] mt-2">0</h3>
                <p class="text-[10px] text-[#4F6D7A]/80 mt-1 font-semibold">Flagged from target repositories</p>
            </div>

            <!-- Metric Card 3 -->
            <div class="bg-[#C0D6DF]/20 border border-[#4F6D7A] p-8 relative transition-all duration-200 hover:bg-[#C0D6DF]/30">
                <p class="text-[10px] font-bold text-[#4F6D7A]/70 uppercase tracking-wider">Patches Pushed</p>
                <h3 id="metricPatches" class="text-3xl font-bold text-[#4F6D7A] mt-2">0</h3>
                <p class="text-[10px] text-[#4F6D7A]/80 mt-1 font-semibold">Applied directly back to repository</p>
            </div>

            <!-- Metric Card 4 -->
            <div class="bg-[#C0D6DF]/20 border border-[#4F6D7A] p-8 relative transition-all duration-200 hover:bg-[#C0D6DF]/30">
                <p class="text-[10px] font-bold text-[#4F6D7A]/70 uppercase tracking-wider">Branches Created</p>
                <h3 class="text-3xl font-bold text-[#4F6D7A] mt-2">5</h3>
                <p class="text-[10px] text-[#4F6D7A]/80 mt-1 font-semibold">Remediation paths tested</p>
            </div>
        </div>

        <!-- Security Activity Feed Section -->
        <div class="bg-white border border-[#4F6D7A] p-10 space-y-8">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-[#4F6D7A]/20 pb-6">
                <div>
                    <h2 class="text-lg font-bold text-[#4F6D7A] uppercase tracking-wider">Security Activity Feed</h2>
                    <p class="text-[#4F6D7A]/75 text-xs mt-1">Review live branch remediations for specific project environments.</p>
                </div>
                
                <!-- Repo Selection Pills -->
                <div class="flex border border-[#4F6D7A] bg-[#C0D6DF]/15 p-1">
                    <button onclick="switchRepo('SoftHive-group/Internal-Tools')" id="repo-softhive" 
                            class="px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-200 bg-[#E8DAB2] text-[#4F6D7A] cursor-pointer">
                        SoftHive-group/Internal-Tools
                    </button>
                    <button onclick="switchRepo('Guardian-Shield/Web-Portal')" id="repo-guardian" 
                            class="px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-200 text-[#4F6D7A]/60 hover:text-[#4F6D7A] hover:bg-[#C0D6DF]/30 cursor-pointer">
                        Guardian-Shield/Web-Portal
                    </button>
                </div>
            </div>

            <!-- Feed Grid Container -->
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8" id="activityFeedContainer">
                <!-- Dynamically populated by JS -->
            </div>
        </div>
    </main>

    <script>
        function switchRepo(repoName) {
            const btnSoftHive = document.getElementById('repo-softhive');
            const btnGuardian = document.getElementById('repo-guardian');

            const activeClass = 'bg-[#E8DAB2] text-[#4F6D7A]';
            const inactiveClass = 'text-[#4F6D7A]/60 hover:text-[#4F6D7A] hover:bg-[#C0D6DF]/30';

            if (repoName === 'SoftHive-group/Internal-Tools') {
                btnSoftHive.className = `px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-200 ${activeClass} cursor-pointer`;
                btnGuardian.className = `px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-200 ${inactiveClass} cursor-pointer`;
            } else {
                btnGuardian.className = `px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-200 ${activeClass} cursor-pointer`;
                btnSoftHive.className = `px-4 py-2 text-xs font-bold uppercase tracking-wider transition-all duration-200 ${inactiveClass} cursor-pointer`;
            }

            // Fetch table data via Express API
            fetch(`/api/scans/${encodeURIComponent(repoName)}`)
                .then(response => response.json())
                .then(data => {
                    const feedContainer = document.getElementById('activityFeedContainer');
                    feedContainer.innerHTML = '';

                    const totalVulns = data.scans.length;
                    const totalPatched = data.scans.filter(s => s.status.includes('✅')).length;

                    document.getElementById('metricVulns').innerText = totalVulns;
                    document.getElementById('metricPatches').innerText = totalPatched;

                    if (totalVulns === 0) {
                        feedContainer.innerHTML = `
                            <div class="col-span-full border border-dashed border-[#4F6D7A]/55 p-12 text-center">
                                <p class="text-xs text-[#4F6D7A] font-bold uppercase tracking-wider">No scans recorded for this repository.</p>
                            </div>
                        `;
                        return;
                    }

                    data.scans.forEach(s => {
                        const fileSlug = s.file.replace(/[^a-zA-Z0-9]/g, '_');
                        const branchName = `guardian/remediate-${fileSlug}_${s.line}`;
                        const isGitLab = s.repo_name.toLowerCase().includes('gitlab') || s.repo_name.includes('SoftHive-group');
                        const branchUrl = isGitLab 
                            ? `https://gitlab.com/${s.repo_name}/-/tree/${branchName}` 
                            : `https://github.com/${s.repo_name}/tree/${branchName}`;

                        const isPatched = s.status.includes('✅') || s.status.includes('Patched');

                        let scoreBadgeClass = 'bg-[#C0D6DF]/20 text-[#4F6D7A] border-[#4F6D7A]/30';
                        if (s.consensus_score >= 80) {
                            scoreBadgeClass = 'bg-[#DD6E42]/10 text-[#DD6E42] border-[#DD6E42]/30';
                        } else if (s.consensus_score >= 50) {
                            scoreBadgeClass = 'bg-[#E8DAB2]/20 text-[#4F6D7A] border-[#E8DAB2]/60';
                        }

                        const statusText = isPatched ? 'Patched' : 'Failed to Apply';
                        const statusClass = isPatched ? 'text-emerald-700 font-bold' : 'text-[#DD6E42] font-bold';

                        const card = document.createElement('div');
                        card.className = 'bg-white border border-[#4F6D7A] p-8 space-y-6 flex flex-col justify-between transition-all duration-200 hover:border-[#4F6D7A]/70';
                        card.innerHTML = `
                            <div class="space-y-4">
                                <div class="flex items-center justify-between">
                                    <span class="font-mono text-xs text-[#4F6D7A] bg-[#C0D6DF]/20 px-2 py-1 border border-[#4F6D7A]/30">
                                        \${s.file}:L\${s.line}
                                    </span>
                                    <span class="text-xs font-bold uppercase tracking-widest px-2.5 py-1 border \${scoreBadgeClass}">
                                        Consensus: \${s.consensus_score}%
                                    </span>
                                </div>
                                
                                <div>
                                    <h3 class="text-base font-bold text-[#4F6D7A] tracking-tight">\${s.vulnerability}</h3>
                                    <p class="text-xs text-[#4F6D7A]/80 mt-1.5 leading-relaxed">\${s.description}</p>
                                </div>
                            </div>
                            
                            <div class="space-y-4">
                                <div class="grid grid-cols-4 gap-2 text-[9px] font-bold uppercase tracking-wider text-center border-t border-[#4F6D7A]/20 pt-4">
                                    <div class="py-1 bg-[#4F6D7A] text-white border border-[#4F6D7A]">Detected</div>
                                    <div class="py-1 bg-[#4F6D7A] text-white border border-[#4F6D7A]">AI Review</div>
                                    \${isPatched ? `
                                        <div class="py-1 bg-[#4F6D7A] text-white border border-[#4F6D7A]">Patched</div>
                                        <div class="py-1 bg-[#4F6D7A] text-white border border-[#4F6D7A]">Pushed</div>
                                    ` : `
                                        <div class="py-1 bg-white border border-[#DD6E42] text-[#DD6E42]">Failed</div>
                                        <div class="py-1 bg-white border border-[#4F6D7A]/20 text-[#4F6D7A]/30 font-medium">Blocked</div>
                                    `}
                                </div>
                                
                                <div class="flex items-center justify-between border-t border-[#4F6D7A]/20 pt-4">
                                    <span class="text-[11px] font-semibold text-[#4F6D7A]">
                                        Status: <strong class="\${statusClass}">\${statusText}</strong>
                                    </span>
                                    <a href="\${branchUrl}" target="_blank" 
                                       class="bg-[#DD6E42] hover:opacity-90 text-white font-bold uppercase tracking-wider text-[10px] px-3.5 py-1.5 transition-all duration-200 cursor-pointer">
                                        View Sub-Branch
                                    </a>
                                </div>
                            </div>
                        `;
                        feedContainer.appendChild(card);
                    });
                })
                .catch(err => {
                    console.error('Error switching repository scans:', err);
                });
        }

        document.addEventListener('DOMContentLoaded', () => {
            switchRepo('SoftHive-group/Internal-Tools');
        });
    </script>
</body>
</html>
