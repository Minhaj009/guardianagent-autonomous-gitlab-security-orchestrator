<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>GuardianAgent - Developer Console</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Courier+Prime&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary": "#375561",
                        "primary-container": "#4f6d7a",
                        "background": "#f2fbff",
                        "surface": "#ffffff",
                        "surface-dim": "#c8dee7",
                        "surface-bright": "#f2fbff",
                        "on-surface": "#091e25",
                        "on-surface-variant": "#42484b",
                        "outline": "#72787b",
                        "outline-variant": "#c2c7cb",
                        "secondary": "#a04118",
                        "secondary-container": "#fe8859",
                        "tertiary": "#685e3e",
                        "tertiary-container": "#b7ab86"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "2xl": "1.5rem"
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .status-pulse {
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(79, 109, 122, 0.4); }
            70% { box-shadow: 0 0 0 6px rgba(79, 109, 122, 0); }
            100% { box-shadow: 0 0 0 0 rgba(79, 109, 122, 0); }
        }
    </style>
</head>
<body class="bg-background text-on-surface antialiased min-h-screen pb-72">

    <!-- Sticky Top Navigation -->
    <header class="bg-surface sticky top-0 w-full z-50 border-b border-outline-variant">
        <div class="flex justify-between items-center w-full px-6 h-16 max-w-7xl mx-auto">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">shield</span>
                    <span class="font-bold text-lg text-primary tracking-tight">GuardianAgent</span>
                    <span class="text-[10px] border border-outline text-primary px-1.5 py-0.5 ml-2 font-mono uppercase font-bold rounded">v1.0.0</span>
                </div>
                <nav class="hidden md:flex items-center gap-6 ml-4">
                    <a href="/dashboard" class="text-xs font-bold uppercase tracking-wider transition-all duration-200 py-1.5 px-3 border border-outline-variant/30 <%= currentPath === '/dashboard' ? 'bg-surface-dim text-primary' : 'text-on-surface-variant hover:text-primary' %> rounded-lg cursor-pointer">
                        Review Dashboard
                    </a>
                    <a href="/setup/gitlab" class="text-xs font-bold uppercase tracking-wider transition-all duration-200 py-1.5 px-3 border border-outline-variant/30 <%= currentPath === '/setup/gitlab' ? 'bg-surface-dim text-primary' : 'text-on-surface-variant hover:text-primary' %> rounded-lg cursor-pointer">
                        GitLab Setup
                    </a>
                </nav>
            </div>
            
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 bg-surface-dim px-3 py-1.5 rounded-full border border-outline-variant">
                    <span class="w-2 h-2 rounded-full bg-primary-container status-pulse"></span>
                    <span class="text-[10px] font-bold text-primary uppercase tracking-wider">Pipeline Live</span>
                </div>
                <div class="text-right hidden sm:block">
                    <p class="text-[10px] text-on-surface-variant uppercase tracking-widest font-semibold">User</p>
                    <p class="text-xs font-bold text-primary"><%= userEmail %></p>
                </div>
                <a href="/logout" class="py-2 px-3 border border-outline text-xs font-bold uppercase tracking-wider text-primary hover:bg-surface-dim transition-all duration-200 cursor-pointer rounded-lg" title="Logout">
                    Logout
                </a>
            </div>
        </div>
    </header>

    <!-- Main Canvas -->
    <main class="max-w-7xl mx-auto px-6 py-10 space-y-10">
        
        <!-- Header -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h1 class="text-2xl font-bold uppercase tracking-tight text-primary">Security Review Console</h1>
                <p class="text-on-surface-variant text-xs mt-1.5 font-medium">Verify consensus reviews and patches generated by autonomous agent ensembles.</p>
            </div>
            <div class="inline-flex items-center gap-2 px-3.5 py-2 bg-emerald-50 border border-emerald-300 text-emerald-700 text-[10px] font-bold uppercase tracking-wider rounded-lg">
                <span class="material-symbols-outlined text-xs">security</span>
                <span>Live Audit Connected</span>
            </div>
        </div>

        <!-- KPI Metrics Grid -->
        <section class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <!-- Card 2 -->
            <div class="bg-surface rounded-2xl p-6 border border-outline-variant relative overflow-hidden group hover:border-primary transition-colors shadow-sm">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-secondary"></div>
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">Vulnerabilities Found</p>
                <h3 id="metricVulns" class="text-3xl font-bold text-on-surface">0</h3>
                <p class="text-[10px] text-secondary mt-2 font-semibold">Flagged in target repositories</p>
            </div>
            <!-- Card 3 -->
            <div class="bg-surface rounded-2xl p-6 border border-outline-variant relative overflow-hidden group hover:border-primary transition-colors shadow-sm">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-emerald-500"></div>
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">Patches Pushed</p>
                <h3 id="metricPatches" class="text-3xl font-bold text-on-surface">0</h3>
                <p class="text-[10px] text-emerald-600 mt-2 font-semibold">Applied directly to repository</p>
            </div>
            <!-- Card 4 -->
            <div class="bg-surface rounded-2xl p-6 border border-outline-variant relative overflow-hidden group hover:border-primary transition-colors shadow-sm">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-tertiary"></div>
                <p class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">Branches Tested</p>
                <h3 id="metricBranches" class="text-3xl font-bold text-on-surface">0</h3>
                <p class="text-[10px] text-tertiary mt-2 font-semibold">Remediation paths verified</p>
            </div>
        </section>

        <!-- Trigger Manual Security Scan Panel -->
        <section class="bg-surface rounded-2xl border border-outline-variant p-6 shadow-sm space-y-6">
            <div>
                <h2 class="text-base font-bold text-primary uppercase tracking-wider">Trigger Manual Security Scan</h2>
                <p class="text-on-surface-variant text-[11px] mt-1 font-medium">Run an on-demand Gemini-powered security audit and patching cycle on a Merge Request.</p>
            </div>
            
            <form id="manualScanForm" onsubmit="triggerManualScan(event)" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-wider text-on-surface-variant mb-2">GitLab Project ID / Path</label>
                    <input type="text" id="scan_repo_name" required placeholder="soft-hive-group/project"
                           class="w-full bg-background border border-outline-variant rounded-lg text-on-surface text-xs px-4 py-2.5 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-semibold">
                </div>
                <div>
                    <label class="block text-[10px] font-bold uppercase tracking-wider text-on-surface-variant mb-2">Merge Request IID (Internal ID)</label>
                    <input type="number" id="scan_mr_iid" required placeholder="5"
                           class="w-full bg-background border border-outline-variant rounded-lg text-on-surface text-xs px-4 py-2.5 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary font-semibold">
                </div>
                <div>
                    <button type="submit" id="btnTriggerScan"
                            class="w-full py-3 bg-secondary hover:opacity-90 text-white text-xs font-bold uppercase tracking-wider rounded-lg cursor-pointer transition-all duration-200 shadow-sm flex items-center justify-center gap-1.5">
                        <span class="material-symbols-outlined text-sm">play_arrow</span>
                        Run Security Scan
                    </button>
                </div>
            </form>
            <div id="scanStatusMessage" class="hidden text-xs font-semibold uppercase tracking-wider p-3 rounded-lg border"></div>
        </section>

        <!-- Security Activity Feed Section -->
        <section class="bg-surface rounded-2xl border border-outline-variant p-8 space-y-6 shadow-sm">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-outline-variant/30 pb-6">
                <div>
                    <h2 class="text-base font-bold text-primary uppercase tracking-wider">Security Activity Feed</h2>
                    <p class="text-on-surface-variant text-xs mt-1 font-medium">Review live branch remediations for specific project environments.</p>
                </div>
                
                <!-- Repo Selection Pills -->
                <div class="flex flex-wrap border border-outline-variant bg-background p-1 rounded-xl" id="repoPillsContainer">
                    <% if (activeRepos && activeRepos.length > 0) { %>
                        <% activeRepos.forEach((repo, idx) => { %>
                            <button onclick="switchRepo('<%= repo %>')" 
                                    class="repo-pill px-4 py-2 text-xs font-bold uppercase tracking-wider rounded-lg transition-all duration-200 cursor-pointer <%= idx === 0 ? 'bg-primary text-white shadow-sm' : 'text-on-surface-variant hover:text-primary' %>">
                                <%= repo %>
                            </button>
                        <% }); %>
                    <% } else { %>
                        <span class="text-[10px] text-on-surface-variant font-bold uppercase p-2">No active repositories connected.</span>
                    <% } %>
                </div>
            </div>

            <!-- Feed Grid Container -->
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-6" id="activityFeedContainer">
                <!-- Dynamically populated by switchRepo() -->
            </div>
        </section>
    </main>

    <!-- Bottom Live Ensemble Streams Console -->
    <aside id="consoleDrawer" class="fixed bottom-0 left-0 w-full h-64 bg-slate-950 border-t border-outline text-slate-100 z-50 flex flex-col font-mono text-xs transition-all duration-300">
        <div class="sticky top-0 flex items-center justify-between px-4 py-2 bg-slate-900 border-b border-outline-variant/20 cursor-pointer" onclick="toggleConsoleDrawer()">
            <div class="flex items-center gap-2 text-primary-fixed-dim">
                <span class="material-symbols-outlined animate-spin text-[18px]">sync</span>
                <span class="font-bold tracking-wider uppercase text-[10px] text-white">Live Ensemble Execution Streams</span>
            </div>
            <div class="flex items-center gap-3 text-on-surface-variant">
                <span id="console-arrow" class="material-symbols-outlined text-white text-base">expand_more</span>
            </div>
        </div>
        <div id="consoleLogsContainer" class="flex-1 overflow-y-auto p-4 space-y-1.5 select-text">
            <!-- Dynamically populated by switchRepo() logs -->
        </div>
    </aside>

    <script>
        function escapeHtml(text) {
            if (!text) return '';
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function approveScan(scanId, event) {
            if (event) event.preventDefault();
            if (!confirm('Are you sure you want to approve and commit this patch?')) return;
            
            const btn = event ? event.target : null;
            if (btn) {
                btn.disabled = true;
                btn.innerText = 'Committing...';
            }
            
            fetch(`/api/scans/${scanId}/approve`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(async response => {
                const data = await response.json();
                if (response.ok && data.success) {
                    alert(`Patch approved and committed successfully! Commit SHA: ${data.commit_sha}`);
                    const repoName = document.getElementById('repo-softhive').className.includes('bg-primary') 
                        ? 'SoftHive-group/Internal-Tools' 
                        : 'Guardian-Shield/Web-Portal';
                    switchRepo(repoName);
                } else {
                    alert(`Failed to approve: ${data.error || 'Unknown error'}`);
                    if (btn) {
                        btn.disabled = false;
                        btn.innerText = 'Approve & Commit';
                    }
                }
            })
            .catch(err => {
                console.error('Error approving scan:', err);
                alert('An error occurred while approving the patch.');
                if (btn) {
                    btn.disabled = false;
                    btn.innerText = 'Approve & Commit';
                }
            });
        }

        function rejectScan(scanId) {
            if (!confirm('Are you sure you want to reject this patch?')) return;
            
            fetch(`/api/scans/${scanId}/reject`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(async response => {
                const data = await response.json();
                if (response.ok && data.success) {
                    alert('Patch rejected.');
                    const repoName = document.getElementById('repo-softhive').className.includes('bg-primary') 
                        ? 'SoftHive-group/Internal-Tools' 
                        : 'Guardian-Shield/Web-Portal';
                    switchRepo(repoName);
                } else {
                    alert(`Failed to reject: ${data.error || 'Unknown error'}`);
                }
            })
            .catch(err => {
                console.error('Error rejecting scan:', err);
                alert('An error occurred while rejecting the patch.');
            });
        }

        function triggerManualScan(event) {
            event.preventDefault();
            const repoName = document.getElementById('scan_repo_name').value.trim();
            const mrIid = document.getElementById('scan_mr_iid').value.trim();
            const btn = document.getElementById('btnTriggerScan');
            const statusDiv = document.getElementById('scanStatusMessage');
            
            if (!repoName || !mrIid) return;
            
            btn.disabled = true;
            btn.innerText = 'Triggering Scan...';
            
            statusDiv.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'border-red-400/50', 'bg-emerald-50', 'text-emerald-700', 'border-emerald-400/50');
            statusDiv.classList.add('bg-blue-50', 'text-blue-700', 'border', 'border-blue-400/50');
            statusDiv.innerText = '🔄 Security scan requested. Initiating autonomous audit agent ensemble...';
            
            fetch('/api/scans/trigger', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    repo_name: repoName,
                    mr_iid: parseInt(mrIid)
                })
            })
            .then(async response => {
                const data = await response.json();
                btn.disabled = false;
                btn.innerText = 'Run Security Scan';
                
                if (response.ok && data.success) {
                    statusDiv.classList.remove('bg-blue-50', 'text-blue-700', 'border-blue-400/50');
                    statusDiv.classList.add('bg-emerald-50', 'text-emerald-700', 'border', 'border-emerald-400/50');
                    statusDiv.innerText = '✅ ' + data.message;
                    
                    // Automatically switch to the repository to see findings after a delay
                    setTimeout(() => {
                        switchRepo(repoName);
                    }, 3000);
                } else {
                    statusDiv.classList.remove('bg-blue-50', 'text-blue-700', 'border-blue-400/50');
                    statusDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-400/50');
                    statusDiv.innerText = '❌ Failed: ' + (data.error || 'Unknown error');
                }
            })
            .catch(err => {
                console.error('Error triggering manual scan:', err);
                btn.disabled = false;
                btn.innerText = 'Run Security Scan';
                statusDiv.classList.remove('bg-blue-50', 'text-blue-700', 'border-blue-400/50');
                statusDiv.classList.add('bg-red-50', 'text-red-700', 'border', 'border-red-400/50');
                statusDiv.innerText = '❌ Failed to connect to scan trigger endpoint.';
            });
        }



        let isConsoleCollapsed = false;
        function toggleConsoleDrawer() {
            const drawer = document.getElementById('consoleDrawer');
            const arrow = document.getElementById('console-arrow');
            if (isConsoleCollapsed) {
                drawer.style.height = '16rem';
                arrow.textContent = 'expand_more';
                isConsoleCollapsed = false;
            } else {
                drawer.style.height = '2.5rem';
                arrow.textContent = 'expand_less';
                isConsoleCollapsed = true;
            }
        }

        function submitFeedback(scanId, rating) {
            fetch(`/api/scans/${scanId}/feedback`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ feedback: rating })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    const repoName = document.getElementById('repo-softhive').className.includes('bg-primary') 
                        ? 'SoftHive-group/Internal-Tools' 
                        : 'Guardian-Shield/Web-Portal';
                    switchRepo(repoName);
                }
            })
            .catch(err => console.error('Error submitting feedback:', err));
        }

        // Simulated terminal logs corresponding to repos
        const logsData = {
            'SoftHive-group/Internal-Tools': [
                { time: '08:14:02', tag: '[Vertex AI Orchestrator]', msg: 'Ensemble launched. Active models: Gemini-1.5-Pro, Gemini-1.5-Flash.', color: 'text-indigo-400' },
                { time: '08:14:04', tag: '[Gemini-1.5-Flash]', msg: 'Scanning vulnerable_service.py:L7 for cloud credentials leak...', color: 'text-emerald-400' },
                { time: '08:14:05', tag: '[Consensus Engine]', msg: 'Hardcoded AWS Key confirmed (100% consensus across 4 models).', color: 'text-amber-400' },
                { time: '08:14:07', tag: '[Auto-Remediation]', msg: 'Conflict marker patch created. Writing patch to disk...', color: 'text-coral-500' },
                { time: '08:14:10', tag: '[Git Orchestrator]', msg: 'Remediation pushed to branch: guardian/remediate-vulnerable_service_py_7. Skip-CI applied.', color: 'text-blue-400' },
                { time: '08:14:15', tag: '[Gemini-1.5-Pro]', msg: 'Analyzing L20 direct user-input formats in sqlite3 query string...', color: 'text-emerald-400' },
                { time: '08:14:18', tag: '[Consensus Engine]', msg: 'SQL Injection confirmed (100% consensus). Synthesizing unified description...', color: 'text-amber-400' },
                { time: '08:14:20', tag: '[Auto-Remediation]', msg: 'Remediated SQL Injection with parameterized variables. Pushed successfully.', color: 'text-emerald-500' }
            ],
            'Guardian-Shield/Web-Portal': [
                { time: '08:22:11', tag: '[Vertex AI Orchestrator]', msg: 'Active models initialized. Scanning routes/auth.js:L44...', color: 'text-indigo-400' },
                { time: '08:22:13', tag: '[Gemini-1.5-Flash]', msg: 'Analyzing MD5 passwords usage in registration modules.', color: 'text-emerald-400' },
                { time: '08:22:15', tag: '[Consensus Engine]', msg: 'Weak Cryptography detected (33% confidence match). AI Review triggered.', color: 'text-amber-400' },
                { time: '08:22:17', tag: '[Auto-Remediation]', msg: 'Upgrading MD5 to bcrypt. Patch verified and pushed to sub-branch.', color: 'text-emerald-500' },
                { time: '08:22:20', tag: '[Gemini-1.5-Pro]', msg: 'Scanning controllers/fileUpload.js:L105 path traversal vectors.', color: 'text-emerald-400' },
                { time: '08:22:22', tag: '[Consensus Engine]', msg: 'Path Traversal detected (40% consensus). Generating auto-fix patch...', color: 'text-amber-400' },
                { time: '08:22:25', tag: '[Auto-Remediation]', msg: 'ERROR: Original block matching failed. Local patch aborted.', color: 'text-red-400' }
            ]
        };

        function populateLogs(repoName) {
            const container = document.getElementById('consoleLogsContainer');
            if (!container) return;
            container.innerHTML = '';
            const logs = logsData[repoName] || [];
            logs.forEach(log => {
                const line = document.createElement('div');
                line.className = 'flex gap-2 leading-relaxed';
                line.innerHTML = `
                    <span class="text-slate-500 select-none">${log.time}</span>
                    <span class="font-bold ${log.color} select-none">${log.tag}</span>
                    <span class="text-slate-300">${log.msg}</span>
                `;
                container.appendChild(line);
            });
            // Auto scroll to bottom
            container.scrollTop = container.scrollHeight;
        }

        function switchRepo(repoName) {
            const pills = document.querySelectorAll('.repo-pill');
            pills.forEach(pill => {
                if (pill.textContent.trim() === repoName) {
                    pill.className = 'repo-pill px-4 py-2 text-xs font-bold uppercase tracking-wider rounded-lg transition-all duration-200 cursor-pointer bg-primary text-white shadow-sm';
                } else {
                    pill.className = 'repo-pill px-4 py-2 text-xs font-bold uppercase tracking-wider rounded-lg transition-all duration-200 cursor-pointer text-on-surface-variant hover:text-primary';
                }
            });

            // Populate terminal logs corresponding to active repo
            populateLogs(repoName);

            // Fetch scan data
            fetch(`/api/scans/${encodeURIComponent(repoName)}`)
                .then(response => response.json())
                .then(data => {
                    const feedContainer = document.getElementById('activityFeedContainer');
                    feedContainer.innerHTML = '';

                    const totalVulns = data.scans.length;
                    const totalPatched = data.scans.filter(s => s.status.includes('✅')).length;
                    const uniqueBranches = new Set(data.scans.map(s => {
                        const fileSlug = s.file.replace(/[^a-zA-Z0-9]/g, '_');
                        return `guardian/remediate-${fileSlug}_${s.line}`;
                    })).size;

                    document.getElementById('metricVulns').innerText = totalVulns;
                    document.getElementById('metricPatches').innerText = totalPatched;
                    document.getElementById('metricBranches').innerText = uniqueBranches;

                    if (totalVulns === 0) {
                        feedContainer.innerHTML = `
                            <div class="col-span-full border border-dashed border-outline rounded-2xl p-12 text-center bg-surface">
                                <span class="material-symbols-outlined text-outline-variant text-4xl mb-2">grid_view</span>
                                <p class="text-xs text-on-surface-variant font-bold uppercase tracking-wider">No scans recorded for this repository.</p>
                            </div>
                        `;
                        return;
                    }

                    data.scans.forEach(s => {
                        const fileSlug = s.file.replace(/[^a-zA-Z0-9]/g, '_');
                        const branchName = `guardian/remediate-${fileSlug}_${s.line}`;
                        const isGitLab = s.repo_name.toLowerCase().includes('gitlab') || s.repo_name.includes('SoftHive-group');
                        const branchUrl = isGitLab 
                            ? `https://gitlab.com/${s.repo_name}/-/tree/${branchName}` 
                            : `https://github.com/${s.repo_name}/tree/${branchName}`;

                        const isPatched = s.status.includes('✅') || s.status.includes('Patched');
                        const isPending = s.status === 'Pending Approval';
                        const isRejected = s.status.includes('Rejected');

                        let scoreBadgeClass = 'bg-background text-primary border-outline-variant';
                        if (s.consensus_score >= 80) {
                            scoreBadgeClass = 'bg-red-50 text-red-700 border-red-200';
                        } else if (s.consensus_score >= 50) {
                            scoreBadgeClass = 'bg-amber-50 text-amber-700 border-amber-200';
                        }

                        let statusText = s.status;
                        let statusClass = 'text-primary font-bold bg-surface-dim px-2 py-0.5 border border-outline-variant rounded';

                        if (isPatched) {
                            statusText = s.status.replace('✅', '').trim();
                            statusClass = 'text-emerald-700 font-bold bg-emerald-50 px-2 py-0.5 border border-emerald-200 rounded';
                        } else if (isPending) {
                            statusText = 'Pending Approval';
                            statusClass = 'text-amber-700 font-bold bg-amber-50 px-2 py-0.5 border border-amber-200 rounded';
                        } else if (isRejected) {
                            statusText = 'Rejected';
                            statusClass = 'text-secondary font-bold bg-red-50 px-2 py-0.5 border border-red-200 rounded';
                        } else {
                            statusClass = 'text-secondary font-bold bg-red-50 px-2 py-0.5 border border-red-200 rounded';
                        }

                        const card = document.createElement('article');
                        card.className = 'bg-surface rounded-2xl border border-outline-variant p-6 flex flex-col justify-between hover:border-primary transition-all shadow-sm';
                        
                        let diffHtml = '';
                        if (isPending && s.original_code && s.corrected_code) {
                            diffHtml = `
                                <div class="mt-4 border border-outline-variant rounded-xl p-3 bg-slate-950 text-[10px] font-mono leading-tight overflow-x-auto text-slate-100 grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="text-red-400 border-r border-slate-800 pr-2">
                                        <span class="font-bold block uppercase tracking-wider text-[8px] opacity-75 mb-1 text-red-500">Vulnerable Code (Original)</span>
                                        <pre class="bg-red-950/20 p-2 whitespace-pre overflow-x-auto rounded border border-red-900/30">\${escapeHtml(s.original_code)}</pre>
                                    </div>
                                    <div class="text-emerald-400 pl-2">
                                        <span class="font-bold block uppercase tracking-wider text-[8px] opacity-75 mb-1 text-emerald-500">Secure Patch (Remediated)</span>
                                        <pre class="bg-emerald-950/20 p-2 whitespace-pre overflow-x-auto rounded border border-emerald-900/30">\${escapeHtml(s.corrected_code)}</pre>
                                    </div>
                                </div>
                            `;
                        }

                        let actionsHtml = '';
                        if (isPending) {
                            actionsHtml = `
                                <div class="flex items-center gap-2">
                                    <button onclick="approveScan(\${s.id}, event)" 
                                            class="bg-primary hover:opacity-90 text-white font-bold uppercase tracking-wider text-[9px] px-3 py-2 rounded-lg transition-all duration-200 cursor-pointer shadow-sm flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[12px]">done</span> Approve & Commit
                                    </button>
                                    <button onclick="rejectScan(\${s.id})" 
                                            class="border border-secondary text-secondary hover:bg-secondary/10 font-bold uppercase tracking-wider text-[9px] px-3 py-2 rounded-lg transition-all duration-200 cursor-pointer shadow-sm flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[12px]">close</span> Reject
                                    </button>
                                </div>
                            `;
                        } else {
                            actionsHtml = `
                                <a href="\${branchUrl}" target="_blank" 
                                   class="bg-surface border border-outline-variant hover:border-primary text-primary font-bold uppercase tracking-wider text-[10px] px-3.5 py-2 rounded-lg transition-all duration-200 cursor-pointer shadow-sm flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[12px]">open_in_new</span> View Sub-Branch
                                </a>
                            `;
                        }

                        card.innerHTML = `
                            <div class="space-y-4">
                                <div class="flex items-center justify-between border-b border-outline-variant/30 pb-3">
                                    <span class="font-mono text-[11px] text-on-surface-variant bg-background px-2.5 py-1 border border-outline-variant rounded">
                                        \${s.file}:L\${s.line}
                                    </span>
                                    <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 border rounded \${scoreBadgeClass}">
                                        Consensus: \${s.consensus_score}%
                                    </span>
                                </div>
                                
                                <div>
                                    <h4 class="font-bold text-primary text-sm tracking-tight">\${s.vulnerability}</h4>
                                    <p class="text-xs text-on-surface-variant mt-1.5 leading-relaxed">\${s.description}</p>
                                </div>
                                \${diffHtml}
                            </div>
                            
                            <div class="space-y-4 mt-6">
                                <!-- Stepper Progress Line -->
                                <div class="flex items-center justify-between w-full my-2">
                                    <div class="flex flex-col items-center gap-1">
                                        <div class="w-4 h-4 rounded-full bg-primary flex items-center justify-center text-white"><span class="material-symbols-outlined text-[10px]" style="font-variation-settings: 'FILL' 1;">check</span></div>
                                        <span class="text-[9px] font-bold text-primary">Detected</span>
                                    </div>
                                    <div class="h-px bg-primary flex-1 mx-2 mt-[-16px]"></div>
                                    <div class="flex flex-col items-center gap-1">
                                        <div class="w-4 h-4 rounded-full bg-primary flex items-center justify-center text-white"><span class="material-symbols-outlined text-[10px]" style="font-variation-settings: 'FILL' 1;">check</span></div>
                                        <span class="text-[9px] font-bold text-primary">AI Review</span>
                                    </div>
                                    <div class="h-px \${isPatched ? 'bg-primary' : 'bg-outline-variant'} flex-1 mx-2 mt-[-16px]"></div>
                                    <div class="flex flex-col items-center gap-1">
                                        <div class="w-4 h-4 rounded-full \${isPatched ? 'bg-primary flex items-center justify-center text-white' : (isPending ? 'bg-amber-500 flex items-center justify-center text-white' : 'border-2 border-outline-variant bg-surface')}">
                                            \${isPatched ? '<span class="material-symbols-outlined text-[10px]" style="font-variation-settings: \'FILL\' 1;">check</span>' : (isPending ? '<span class="material-symbols-outlined text-[10px]" style="font-variation-settings: \'FILL\' 1;">pending</span>' : '')}
                                        </div>
                                        <span class="text-[9px] font-bold \${isPatched ? 'text-primary' : (isPending ? 'text-amber-500' : 'text-outline-variant')}">Patched</span>
                                    </div>
                                    <div class="h-px \${isPatched ? 'bg-primary' : 'bg-outline-variant'} flex-1 mx-2 mt-[-16px]"></div>
                                    <div class="flex flex-col items-center gap-1">
                                        <div class="w-4 h-4 rounded-full \${isPatched ? 'bg-primary flex items-center justify-center text-white' : 'border-2 border-outline-variant bg-surface'}">
                                            \${isPatched ? '<span class="material-symbols-outlined text-[10px]" style="font-variation-settings: \'FILL\' 1;">check</span>' : ''}
                                        </div>
                                        <span class="text-[9px] font-bold \${isPatched ? 'text-primary' : 'text-outline-variant'}">Pushed</span>
                                    </div>
                                </div>
                                
                                <div class="flex items-center justify-between border-t border-outline-variant/30 pt-4">
                                    <div class="flex items-center gap-3">
                                        <div class="flex items-center border border-outline-variant bg-background rounded-lg p-0.5">
                                            <button onclick="submitFeedback(\${s.id}, '\${s.feedback === 'up' ? '' : 'up'}')" 
                                                    class="p-1 rounded transition-all duration-200 cursor-pointer \${s.feedback === 'up' ? 'bg-primary text-white' : 'text-on-surface-variant hover:text-primary'}" 
                                                    title="Helpful">
                                                <span class="material-symbols-outlined text-sm block" style="font-variation-settings: 'FILL' \${s.feedback === 'up' ? 1 : 0};">thumb_up</span>
                                            </button>
                                            <button onclick="submitFeedback(\${s.id}, '\${s.feedback === 'down' ? '' : 'down'}')" 
                                                    class="p-1 border-l border-outline-variant rounded transition-all duration-200 cursor-pointer \${s.feedback === 'down' ? 'bg-secondary text-white' : 'text-on-surface-variant hover:text-primary'}" 
                                                    title="Not Helpful">
                                                <span class="material-symbols-outlined text-sm block" style="font-variation-settings: 'FILL' \${s.feedback === 'down' ? 1 : 0};">thumb_down</span>
                                            </button>
                                        </div>
                                        <span class="text-[10px] \${statusClass}">
                                            \${statusText}
                                        </span>
                                    </div>
                                    \${actionsHtml}
                                </div>
                            </div>
                        `;
                        feedContainer.appendChild(card);
                    });
                })
                .catch(err => {
                    console.error('Error switching repository scans:', err);
                });
        }

        const activeRepos = <%- JSON.stringify(activeRepos || []) %>;
        document.addEventListener('DOMContentLoaded', () => {
            if (activeRepos && activeRepos.length > 0) {
                switchRepo(activeRepos[0]);
            }
        });
    </script>
</body>
</html>
