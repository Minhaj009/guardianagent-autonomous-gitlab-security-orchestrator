# Use official lightweight Python image
FROM python:3.10-slim

# Install system dependencies (Git is required for patch and branch operations)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    openssh-client \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy dependency requirements
RUN pip install --no-cache-dir \
    google-genai \
    requests \
    pydantic \
    tenacity

# Copy the scanner script and local database directory for settings verification
COPY guardian.py .
COPY web/ ./web/

# Set environment variables
ENV PYTHONUNBUFFERED=1

# Expose SSE port
EXPOSE 8000

# Run in SSE MCP mode by default for Cloud Run
CMD ["python", "guardian.py", "--mcp-sse", "--mcp-port", "8000"]
